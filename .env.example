# Demo-only: browser-direct Gemini + trackers. Never enable in shared/production deploys.
# Even if set to true here, production builds ignore it — the flag only works when
# import.meta.env.DEV is true (npm run dev). Prefer .env.local over .env.
VITE_ALLOW_INSECURE_CLIENT_LLM=false

# Only used when the insecure flag is enabled under npm run dev.
VITE_GEMINI_API_KEY=

# Phase 3 backend. When set, the UI uses email/password auth and server-side
# generate/export (Gemini key + tracker credentials never in the browser).
# Example: http://localhost:4000
VITE_API_URL=
