# ProdMate backend — Phase 3 (internal project, not public SaaS)
#
# Copy to .env and fill in real values. Never commit .env.

# Server
PORT=4000
NODE_ENV=development
# Comma-separated origins allowed to call the API (Vite default)
CORS_ORIGIN=http://localhost:3000

# Postgres (D2)
DATABASE_URL=postgres://prodmate:prodmate@localhost:5432/prodmate

# Gemini — server-side only. Never expose to the frontend.
GEMINI_API_KEY=

# Session signing secret (random 32+ chars). Used to sign the session cookie value.
SESSION_SECRET=

# -----------------------------------------------------------------------------
# Tracker credential encryption (AES-256-GCM)
# -----------------------------------------------------------------------------
# Phase 3 trade-off: the AES key lives in this environment variable for an
# internal deploy. That is intentional and honest — same bar as bcrypt-vs-argon2id.
#
# Generate a 32-byte key, base64-encoded, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Real secret-manager integration (Azure Key Vault) is a later hardening item
# (Phase 8+), not a Phase 3 blocker.
CREDENTIALS_ENCRYPTION_KEY=

# Phase 8 — per-user rate limits (in-memory; Redis deferred for multi-instance)
RATE_LIMIT_GENERATE_PER_HOUR=10
RATE_LIMIT_EXPORT_PER_HOUR=30
RATE_LIMIT_KNOWLEDGE_INGEST_PER_HOUR=20
# Backlog check embeds up to ~100+ texts; keep tighter than export (default 10/hour)
RATE_LIMIT_BACKLOG_CHECK_PER_HOUR=10
# Metrics + collab (read/interaction) — not Gemini-cost; generous default
RATE_LIMIT_INTERACTION_PER_HOUR=120

# Phase 10 — request ceilings (abort in-flight calls)
GEMINI_TIMEOUT_MS=120000
EMBEDDING_TIMEOUT_MS=60000
TRACKER_FETCH_TIMEOUT_MS=30000

# Phase 8 — audit retention (days). `npm run audit:prune` also deletes expired sessions
# (expires_at < now()). Login also prunes expired sessions opportunistically.
AUDIT_RETENTION_DAYS=90

# Phase 7 — Knowledge Mesh (pgvector on DATABASE_URL)
# Local: docker compose up -d  (uses pgvector/pgvector:pg16 — plain postgres lacks the vector extension)
# Azure Database for PostgreSQL Flexible Server: allow-list extension `vector` in azure.extensions
#   before running npm run migrate (schema_phase7.sql).
#
# Cross-user retrieval isolation test (does NOT use embedded-postgres):
#   TEST_DATABASE_URL=postgres://prodmate:prodmate@localhost:5432/prodmate
# If unset, the HNSW/cosine isolation suite is skipped — not a fake pass.
# TEST_DATABASE_URL=
