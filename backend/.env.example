# ProdMate backend — Phase 3 (internal project, not public SaaS)
#
# Copy to .env and fill in real values. Never commit .env.

# Server
PORT=4000
NODE_ENV=development
# Comma-separated origins allowed to call the API (Vite default)
CORS_ORIGIN=http://localhost:3000

# Postgres (D2)
DATABASE_URL=postgres://prodmate:prodmate@localhost:5432/prodmate

# Gemini — server-side only. Never expose to the frontend.
GEMINI_API_KEY=

# Session signing secret (random 32+ chars). Used to sign the session cookie value.
SESSION_SECRET=

# -----------------------------------------------------------------------------
# Tracker credential encryption (AES-256-GCM)
# -----------------------------------------------------------------------------
# Phase 3 trade-off: the AES key lives in this environment variable for an
# internal deploy. That is intentional and honest — same bar as bcrypt-vs-argon2id.
#
# Generate a 32-byte key, base64-encoded, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Real secret-manager integration (Azure Key Vault) is a later hardening item
# (Phase 8), not a Phase 3 blocker.
CREDENTIALS_ENCRYPTION_KEY=
